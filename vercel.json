{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install && pnpm --filter @workspace/api-server build",
  "builds": [
    {
      "src": "artifacts/api-server/api/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 300 }
    },
    {
      "src": "artifacts/blue-mantis/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "artifacts/dev-copilot/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/artifacts/api-server/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/app(?:/.*)?", "dest": "/app/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
